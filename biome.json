{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "files": {
    "includes": [
      "package.json",
      "biome.json",
      ".htmlvalidate.json",
      "vitest.config.js",
      "tests/**/*.js",
      "chrome-extension/**/*.js",
      "chrome-extension/**/*.css",
      "chrome-extension/manifest.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
