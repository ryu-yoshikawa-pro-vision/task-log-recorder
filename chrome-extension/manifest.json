{
  "manifest_version": 3,
  "name": "作業ログ記録",
  "description": "現在のページを手動で記録し、日付指定でTSVコピーできます。",
  "version": "1.2.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "作業ログ記録",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "options_page": "options.html",
  "commands": {
    "start-log": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "Command+Shift+1"
      },
      "description": "開始を記録"
    },
    "break-log": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "Command+Shift+2"
      },
      "description": "休憩を記録"
    },
    "end-day-log": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "Command+Shift+3"
      },
      "description": "終了を記録"
    }
  }
}
